model Memorial {
    id              String    @id @default(dbgenerated("gen_random_uuid()"))
    slug            String    @unique
    name            String
    category        String
    countryId       String
    occupation      String
    remembrance     String
    potraitUrl      String
    dateOfBirth     DateTime
    dateOfDeath     DateTime
    about           String
    
    createdAt       DateTime @default(now())
    updatedAt       DateTime @updatedAt
    createdBy       String

    timeline        TimelineEntry[]
    memories        Memory[]
    flames           Flames[]
    corrections     Correction[]

    country         Country @relation(fields: [countryId], references: [id])
    createdByUser   User @relation(fields: [createdBy], references: [id])

}

model MemorialSuggestion {
    id          String   @id @default(dbgenerated("gen_random_uuid()"))
    name        String
    country     String
    message     String
}

model Flames {
    id          String   @id @default(dbgenerated("gen_random_uuid()"))
    ipAddress   String   @unique
    memorialId  String?  

    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    memorial     Memorial? @relation(fields: [memorialId], references: [id])
}


model TimelineEntry {
    id          String    @id @default(dbgenerated("gen_random_uuid()"))
    title       String
    description String
    year        Int
    memorialId  String

    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
    
    memorial    Memorial @relation(fields: [memorialId], references: [id])
}

model Memory {
    id          String    @id @default(dbgenerated("gen_random_uuid()"))
    initials    String
    name        String
    message     String
    memorialId  String
    imageUrl    String?
    status      MemoryStatus @default(PENDING)

    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
    
    memorial    Memorial @relation(fields: [memorialId], references: [id])
}

model Correction {
    id          String    @id @default(dbgenerated("gen_random_uuid()"))
    field        String
    note        String
    email       String
    memorialId  String
    status      CorrectionStatus @default(PENDING)

    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
    
    memorial    Memorial @relation(fields: [memorialId], references: [id])
}